<server description="Liberty Authenticated App Server">

    <featureManager>
        <feature>servlet-4.0</feature>
        <feature>jsp-2.3</feature>
        <feature>appSecurity-3.0</feature>
        <feature>transportSecurity-1.0</feature>
        <feature>restConnector-2.0</feature>
        <feature>jaxrs-2.1</feature>
        <feature>jsonb-1.0</feature>
        <feature>jsonp-1.1</feature>
        <feature>openapi-3.0</feature>
    </featureManager>

    <httpEndpoint id="defaultHttpEndpoint"
                  httpPort="9081"
                  httpsPort="9444" />

    <!-- Liberty will auto-generate SSL config when transportSecurity is enabled -->

    <basicRegistry id="basic" realm="BasicRealm">
        <user name="admin" password="adminpwd"/>
        <group name="admin">
            <member name="admin"/>
        </group>
    </basicRegistry>

    <applicationManager autoExpand="true"/>

    <webApplication id="libertyappmon"
                location="libertyappmon-1.0-SNAPSHOT.war"
                contextRoot="/libertyappmon" />

</server>